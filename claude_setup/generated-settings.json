{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Skill",
      "Agent",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(tree *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(less *)",
      "Bash(more *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(ps *)",
      "Bash(top *)",
      "Bash(env *)",
      "Bash(printenv *)",
      "Bash(echo *)",
      "Bash(date *)",
      "Bash(whoami)",
      "Bash(uname *)",
      "Bash(hostname *)",
      "Bash(chmod +x *)",
      "Bash(mkdir -p *)",
      "Bash(cp * ~/source/*)",
      "Bash(cp * /tmp/*)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git ls *)",
      "Bash(git rev-parse *)",
      "Bash(git commit *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(uv run --no-project --script *)",
      "Bash(uv run --no-project --with *)",
      "Bash(uv run --no-project python *)",
      "Bash(uv init *)",
      "Bash(uvx *)",
      "WebFetch",
      "Edit(/tmp/**)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(mount *)",
      "Bash(umount *)",
      "Bash(pip *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pipx *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(systemctl *)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(mv *)",
      "Bash(chmod -* *)",
      "Bash(ln *)",
      "Bash(cat > *)",
      "Bash(source *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git * push *)",
      "Bash(git remote *)",
      "Bash(git * remote)",
      "Bash(uv publish *)",
      "Bash(uv * publish *)",
      "Bash(docker *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus[1m]",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project ~/.claude/hooks/event-logger.py"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project ~/.claude/hooks/event-logger.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project --script ~/.claude/hooks/encourage_skill_usage.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "superpowers:superpowers-dev": true,
    "superpowers@superpowers-dev": true
  },
  "extraKnownMarketplaces": {
    "superpowers-dev": {
      "source": {
        "source": "git",
        "url": "https://github.com/obra/superpowers.git"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "google.com"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "/tmp",
        "~/source",
        "~/.cache"
      ],
      "allowRead": []
    }
  },
  "autoMemoryEnabled": false,
  "additionalDirectories": [
    "/tmp",
    "~/source"
  ]
}
